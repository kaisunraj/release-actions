{
  "name": "release-pr-action",
  "version": "1.0.0",
  "description": "GitHub Action to raise a release PR from a target branch into a base branch",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist --license licenses.txt",
    "test": "jest --coverage",
    "prettier": "prettier --write ."
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "8.0.1",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3",
    "jest": "^29.7.0",
    "prettier": "3.8.1"
  },
  "overrides": {
    "undici": "^6.24.1"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 90
      }
    }
  }
}
