{
  "name": "release-pr-action",
  "version": "1.0.0",
  "description": "GitHub Action to raise a release PR from a target branch into a base branch",
  "scripts": {
    "build:pr": "ncc build src/pr-action.ts -o dist/pr-action --license dist/pr-action/licenses.txt",
    "build:release-notes": "ncc build src/release-notes-action.ts -o dist/release-notes-action --license dist/release-notes/licenses.txt",
    "build": "npm run build:pr && npm run build:release-notes",
    "test": "jest --coverage",
    "prettier": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "bundle": "npx rimraf ./dist && npm run build",
    "check": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "8.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@vercel/ncc": "^0.38.3",
    "jest": "^29.7.0",
    "prettier": "3.8.1",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "undici": "^6.24.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**/*.ts",
      "!./src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 90
      }
    }
  },
  "engines": {
    "node": ">=24 <25"
  }
}
